#
# Пример env-настроек.
# Скопируйте в `.env` и заполните значения.
#

# MySQL
# Для запуска через Docker (make worker) используйте host.docker.internal
# чтобы контейнер мог достучаться до MySQL на хосте.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=avito_reports
DB_USER=avito
DB_PASSWORD=change_me

# Логирование
LOG_LEVEL=info
# LOG_FILE по умолчанию: var/log/worker.log (относительно корня проекта).
# В Docker переопределяется docker-compose.yml -> /app/var/log/worker.log.
# LOG_FILE=var/log/worker.log

# Avito OAuth / API
OAUTH_TOKEN_URL="https://api.avito.ru/token"
AVITO_BASE_URL="https://api.avito.ru"
AVITO_LAST_REPORT_PATH="/autoload/v3/reports/last_completed_report"
AVITO_ERROR_ADS_PATH="/autoload/v2/reports/{report_id}/items?sections=error,publish_with_problems"

# Коды ошибок через запятую. Только объявления с этими кодами сохраняются.
# Если не задан — ничего не сохраняется.
AVITO_ERROR_CODES=1073
