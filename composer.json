{
  "name": "avito-autoload-reports/worker",
  "type": "project",
  "require": {
    "php": "^8.4",
    "doctrine/dbal": "^3.10",
    "guzzlehttp/guzzle": "^7.10"
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "config": {
    "platform": {
      "php": "8.4.0"
    },
    "platform-check": false
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  }
}
